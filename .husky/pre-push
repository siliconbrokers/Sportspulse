SCRIPT_DIR="$(cd "$(dirname "$0")/../scripts" && pwd)"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Cargar credenciales desde .env y .env.local (este ultimo tiene precedencia)
for envfile in "$REPO_ROOT/.env" "$REPO_ROOT/.env.local"; do
  if [ -f "$envfile" ]; then
    set -o allexport
    # shellcheck disable=SC1091
    source "$envfile"
    set +o allexport
  fi
done

# Solo seedear cuando el push va a main
PUSH_TARGET=$(cat -)
BRANCH=$(echo "$PUSH_TARGET" | awk '{print $1}' | sed 's|refs/heads/||')

if [ "$BRANCH" != "main" ]; then
  exit 0
fi

# SKIP_SEED=true omite el seed (usar cuando el servidor esta suspendido o en emergencias)
if [ "${SKIP_SEED:-false}" = "true" ]; then
  echo ""
  echo "[pre-push] SKIP_SEED=true — omitiendo seed."
  echo ""
  exit 0
fi

if [ -z "${ADMIN_SECRET:-}" ] || [ -z "${SEED_URL:-}" ]; then
  echo ""
  echo "[pre-push] ADVERTENCIA: ADMIN_SECRET o SEED_URL no configurados."
  echo "[pre-push] El seed de cache se omite."
  echo ""
  exit 0
fi

echo ""
echo "[pre-push] Seeding cache en produccion..."
# El seed es best-effort: si falla (servidor suspendido, error de red, etc.)
# el push continua igual. El seed no debe bloquear un deploy de emergencia.
OVERWRITE="${OVERWRITE:-true}" ADMIN_SECRET="$ADMIN_SECRET" SEED_URL="$SEED_URL" \
  bash "$SCRIPT_DIR/pack-cache.sh" || echo "[pre-push] Seed fallo — continuando con el push."
echo ""
