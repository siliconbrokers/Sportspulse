# football-data.org API token (free tier: 10 req/min)
# Get yours at: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your_token_here

# Comma-separated competition codes to fetch
# PD=La Liga, PL=Premier League, BL1=Bundesliga, SA=Serie A, FL1=Ligue 1
COMPETITIONS=PD

# API server port
PORT=3000
