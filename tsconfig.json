{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "composite": true,
    "outDir": "dist"
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/canonical" },
    { "path": "packages/signals" },
    { "path": "packages/scoring" },
    { "path": "packages/layout" },
    { "path": "packages/snapshot" },
    { "path": "packages/api" },
    { "path": "packages/web" }
  ]
}
