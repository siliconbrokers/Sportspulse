{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm --filter !@sportpulse/web -r build"
  },
  "deploy": {
    "startCommand": "pnpm start",
    "healthcheckPath": "/api/ui/competition-info?competitionId=comp%3Afootball-data%3APD",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
