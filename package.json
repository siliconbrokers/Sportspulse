{
  "name": "sportpulse",
  "private": true,
  "scripts": {
    "start": "npx dotenv-cli -e .env.production -- tsx server/index.ts",
    "dev:api": "npx dotenv-cli -e .env -- npx tsx --tsconfig tsconfig.server.json server/index.ts",
    "dev:web": "pnpm --filter @sportpulse/web dev",
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:restart": "bash scripts/dev-restart.sh",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\"",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "track-a": "pnpm tsx scripts/run-track-a-observation.ts",
    "backtest:v1:historical": "npx dotenv-cli -e .env -- npx tsx --tsconfig tsconfig.server.json scripts/run-backtest-historical.ts",
    "backtest:v3:historical": "npx dotenv-cli -e .env -- npx tsx --tsconfig tsconfig.server.json scripts/run-backtest-v3-historical.ts",
    "train:calibrator": "npx dotenv-cli -e .env -- npx tsx --tsconfig tsconfig.server.json scripts/train-global-calibrator.ts",
    "train:odds": "npx tsx --tsconfig tsconfig.server.json tools/build-odds-dataset.ts",
    "load:odds": "npx tsx --tsconfig tsconfig.server.json tools/load-odds-to-store.ts",
    "train:logistic": "npx tsx --tsconfig tsconfig.server.json tools/train-logistic.ts",
    "train": "bash scripts/train-logistic-pipeline.sh",
    "backtest": "npx tsx --tsconfig tsconfig.server.json tools/backtest-v3.ts",
    "backtest:ensemble": "npx tsx --tsconfig tsconfig.server.json tools/backtest-v3.ts --ensemble",
    "backtest:nexus": "dotenv -e .env -- tsx --tsconfig tsconfig.server.json tools/backtest-nexus.ts",
    "train:track3": "dotenv -e .env -- tsx --tsconfig tsconfig.server.json tools/train-track3.ts",
    "validate:registry": "pnpm tsx scripts/validate-doc-registry.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "pack-cache": "bash scripts/pack-cache.sh",
    "eval:nexus-gate": "dotenv -e .env -- tsx tools/eval-nexus-gate.ts",
    "odds:backfill": "npx dotenv-cli -e .env -- npx tsx --tsconfig tsconfig.server.json tools/backfill-historical-odds.ts",
    "odds:analyze": "npx dotenv-cli -e .env -- npx tsx --tsconfig tsconfig.server.json tools/analyze-blend-accuracy.ts"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/*/test/**/*.ts": [
      "prettier --write"
    ],
    "docs/**/*.md": [
      "pnpm tsx scripts/validate-doc-registry.ts"
    ],
    "docs/_registry/document-registry.md": [
      "pnpm tsx scripts/validate-doc-registry.ts"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "husky"]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "rss-parser": "^3.13.0",
    "tsx": "^4.21.0"
  }
}
